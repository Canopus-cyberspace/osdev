# ============================================================
# Root whitelist policy
# Track only:
#   /source/
#   /Makefile
#   /.gitignore
# Ignore everything else at repository root.
# ============================================================

/*

!/.gitignore
!/Makefile
!/source/
!/source/**

# ============================================================
# Optional generated files inside source/
# Keep source code tracked, but ignore generated Rust/build cache.
# ============================================================

/source/target/
/source/**/target/

# ============================================================
# Common temporary files
# ============================================================

*.bak
*.bak_*
*.tmp
*.temp
*.orig
*.rej
*~
*.swp
*.swo
.DS_Store

__pycache__/
*.py[cod]